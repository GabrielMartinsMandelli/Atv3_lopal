algoritmo "entrada gratis ou nao"
// Função :ver se a entrada para o show e gratis ou nao
// Autor :Gabriel Martins
// Data : 14/04/2026
// Seção de Declarações
var
idade:real


inicio
// Seção de Comandos
escreva("idade do visitante:")
leia (idade)
se(idade<7)ou(idade>=65)entao
escreval("gratuito")
senao
escreval("tera que pagar hahaha")
fimse
fimalgoritmo
