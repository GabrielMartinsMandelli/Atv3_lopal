algoritmo "estoque do mercadinho do pará"
// Funçăo :ver se esta faltando produtos no mercadinho do pará
// Autor :Gabriel Martins
// Data : 14/04/2026
// Seçăo de Declaraçőes
var
idade:real
javaScript:literal
python:literal
usuario:caractere
inicio
// Seçăo de Comandos
escreva("usuario:")
leia(usuario)
se (usuario="candidato")entao
escreval ("login correto")






-----------------------------------

escreva("idade do candidato:")
leia (idade)
se(idade>=18)ou (idade<18)entao
escreval("idade aceita")senao("idade nao aceita")

se (python="s")ou (python="n")entao
escreval("corriculo aceito") senao ("curriculo năo aceito")

se (javaScript="s")ou (javaScript="n")entao
escreval("curriculo aceito") senao ("curriculo năo aceito")

fimse
fimse
fimse
fimalgoritmo


